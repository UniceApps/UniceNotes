{
  "expo": {
    "name": "UniceNotes",
    "slug": "unicenotes",
    "version": "3.1.0",
    "githubUrl": "https://github.com/UniceApps/UniceNotes",
    "orientation": "portrait",
    "icon": "./src/assets/icon.png",
    "userInterfaceStyle": "automatic",
    "scheme": "unicenotes",
    "updates": {
      "fallbackToCacheTimeout": 0
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "appStoreUrl": "https://apps.apple.com/fr/app/unicenotes/id1668992337",
      "supportsTablet": true,
      "icon": {
        "light": "./src/assets/ios/default.png",
        "dark": "./src/assets/ios/dark.png",
        "tinted": "./src/assets/ios/tinteddark.png"
      },
      "infoPlist": {
        "NSFaceIDUsageDescription": "Connectez-vous sur l'application grâce à l'authentification biométrique.",
        "NSNotificationsUsageDescription": "Recevez des notifications pour être informé de diverses choses.",
        "CFBundleLocalizations": [
          "fr"
        ],
        "CFBundleDevelopmentRegion": "fr",
        "CADisableMinimumFrameDurationOnPhone": true
      },
      "bundleIdentifier": "fr.hugofnm.unicenotes",
      "buildNumber": "13.1.0",
      "config": {
        "usesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "fr.hugofnm.unicenotes",
      "versionCode": 37,
      "adaptiveIcon": {
        "foregroundImage": "./src/assets/android/foreground.png",
        "monochromeImage": "./src/assets/android/monochrome.png",
        "backgroundColor": "#FFFFFF"
      }
    },
    "extra": {
      "eas": {
        "projectId": "ec0ebd57-7227-4cd2-a71e-344e0a5fffe5"
      },
      "bugsnag": {
        "apiKey": "$(BUGSNAG_API_KEY)"
      },
      "github_hash": "$(EAS_BUILD_GIT_COMMIT_HASH)"
    },
    "owner": "hugofnm",
    "plugins": [
      "expo-router",
      "@bugsnag/plugin-expo-eas-sourcemaps",
      [
        "@hugofnm/expo-dynamic-app-icon",
        {
          "unicenotes": {
            "image": "./src/assets/icon.png",
            "prerendered": false
          },
          "old": {
            "image": "./src/assets/icons/icon_old.png",
            "prerendered": false
          },
          "magnet": {
            "image": "./src/assets/icons/icon_magnet.png",
            "prerendered": false
          },
          "ardente": {
            "image": "./src/assets/icons/icon_ardente.png",
            "prerendered": false
          },
          "beach": {
            "image": "./src/assets/icons/icon_beach.png",
            "prerendered": false
          },
          "melted": {
            "image": "./src/assets/icons/icon_melted.png",
            "prerendered": false
          },
          "zoomed": {
            "image": "./src/assets/icons/icon_zoomed.png",
            "prerendered": false
          },
          "monaco": {
            "image": "./src/assets/icons/icon_monaco.png",
            "prerendered": false
          },
          "christmas2023": {
            "image": "./src/assets/icons/icon_christmas2023.png",
            "prerendered": false
          },
          "france": {
            "image": "./src/assets/icons/icon_france.png",
            "prerendered": false
          },
          "glitched": {
            "image": "./src/assets/icons/icon_glitched.png",
            "prerendered": false
          },
          "vaporwave": {
            "image": "./src/assets/icons/icon_vaporwave.png",
            "prerendered": false
          },
          "ios6": {
            "image": "./src/assets/icons/icon_ios6.png",
            "prerendered": true
          }
        }
      ],
      "expo-font",
      "expo-secure-store",
      "expo-web-browser",
      [
        "expo-widgets",
        {
          "bundleIdentifier": "fr.hugofnm.unicenotes.widgets",
          "groupIdentifier": "group.fr.hugofnm.unicenotes",
          "widgets": [
            {
              "name": "NextClassWidget",
              "displayName": "Prochains Cours",
              "description": "Affiche vos deux prochains cours UniceNotes",
              "supportedFamilies": [
                "systemSmall",
                "systemMedium"
              ]
            }
          ]
        }
      ],
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#ffffff",
          "image": "./src/assets/ios/default.png",
          "dark": {
            "image": "./src/assets/ios/dark.png",
            "backgroundColor": "#232323"
          },
          "imageWidth": 200
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}